[user]
	name = Matt Stewart
	email = smtp.matt@gmail.com

[web]
	browser = google-chrome

[core]
	editor = vim

[color]
	ui = auto

[diff]
	tool = vimdiff

[color "branch"]
	current = yellow bold
	local = green bold
	remote = cyan bold

[color "status"]
	added = green bold
	changed = yellow bold
	untracked = red bold

[alias]
	st = "status"
	lg = "log --graph --format='%Cred%h%Creset  %<|(15) %C(white)%s %<|(35) %Creset %Cgreen(%cr)%<|(55)  %C(blue)<%an>%Creset%C(yellow)%d%Creset'"
	co = "checkout"
    b = "branch"
    f = "fetch"
    m = "merge"


